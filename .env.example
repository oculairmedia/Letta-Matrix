# Docker Compose project name
COMPOSE_PROJECT_NAME=matrix-tuwunel-deploy

# Tuwunel Matrix Server Settings
MATRIX_SERVER_NAME=your.matrix.domain
TUWUNEL_DATA_PATH=./tuwunel-data
ALLOW_REGISTRATION=true
MATRIX_REGISTRATION_TOKEN=your_registration_token

# Nginx Settings
NGINX_HTTP_PORT=8008
NGINX_CONFIG_PATH=./nginx_tuwunel_proxy.conf
ELEMENT_CONFIG_PATH=./element-config.json

# Matrix Client Settings
MATRIX_HOMESERVER_URL=http://tuwunel:6167
MATRIX_USERNAME=@letta:your.matrix.domain
MATRIX_PASSWORD=your_bot_password
MATRIX_ROOM_ID=
LETTA_API_URL=http://your-letta-host:8289
LETTA_TOKEN=your_letta_token
LETTA_AGENT_ID=your_letta_agent_id
LOG_LEVEL=INFO

# Host IP (used for service-to-host connections)
HOST_IP=192.168.50.90

# Database (PostgreSQL on host)
DATABASE_URL=postgresql://letta:letta@192.168.50.90:5432/matrix_letta

# Conversation Tracker
CONVERSATION_TRACKER_URL=http://192.168.50.90:3101

# Hayhooks Document Ingest
HAYHOOKS_INGEST_URL=http://192.168.50.90:1416/ingest_document/run

# Matrix Admin Settings
MATRIX_ADMIN_USERNAME=@admin:your.matrix.domain
MATRIX_ADMIN_PASSWORD=your_admin_password
MATRIX_ADMIN_TOKEN=your_matrix_admin_access_token

# Letta Streaming Settings
LETTA_STREAMING_ENABLED=true
LETTA_STREAMING_TIMEOUT=3600.0
LETTA_STREAMING_IDLE_TIMEOUT=120.0
LETTA_STREAMING_LIVE_EDIT=true

# Letta Typing Indicators
LETTA_TYPING_ENABLED=true

# Letta Conversations API (context isolation per room)
LETTA_CONVERSATIONS_ENABLED=false

# Temporal async file processing
TEMPORAL_FILE_PROCESSING_ENABLED=true
TEMPORAL_HOST=192.168.50.90:7233
TEMPORAL_NAMESPACE=matrix
TEMPORAL_TASK_QUEUE=matrix-file-queue

# Letta WS Gateway
LETTA_GATEWAY_ENABLED=true
LETTA_GATEWAY_URL=ws://your-host:8407/api/v1/agent-gateway
LETTA_GATEWAY_API_KEY=your_gateway_api_key

# Voice Features
TRANSCRIPTION_PROVIDER=whisper
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Letta Embedding Configuration
LETTA_EMBEDDING_MODEL=your_embedding_model
LETTA_EMBEDDING_ENDPOINT=http://your-host:11434/v1
LETTA_EMBEDDING_ENDPOINT_TYPE=openai
LETTA_EMBEDDING_DIM=2560
LETTA_EMBEDDING_CHUNK_SIZE=300

# ntfy Alerting
NTFY_URL=http://ntfy:80
NTFY_TOPIC=mxsyn-alerts

# OpenCode Bridge
OPENCODE_BRIDGE_ACCESS_TOKEN=your_opencode_bridge_access_token
LETTA_API_KEY=your_letta_api_key

# LiveKit SFU
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://your.matrix.domain/livekit/sfu
